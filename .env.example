# PostgreSQL Connection Configuration
# Copy this file to .env and adjust as needed

# Database connection
PGHOST=localhost
PGPORT=5432
PGUSER=db_admin
PGPASSWORD=db_admin_pass
PGDATABASE=audit_poc

# Superuser (for initial setup)
PGSUPERUSER=postgres
PGSUPERPASSWORD=postgres

# Benchmark settings
BENCH_CLIENTS=50
BENCH_DURATION=70
BENCH_RUNS=5

# Partition settings
PARTITION_RETENTION_MONTHS=6
PARTITION_TABLESPACE_HOT=pg_default
PARTITION_TABLESPACE_COLD=pg_default
